{
  "name": "@gregperlman/island-scene",
  "version": "0.1.0",
  "description": "2.5D tap-to-move island world renderer for Engage Island. Pure presentational React + PixiJS component.",
  "type": "module",
  "main": "./dist/island-scene.cjs",
  "module": "./dist/island-scene.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/island-scene.js",
      "require": "./dist/island-scene.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "BUILD_TARGET=lib vite build && tsc -p tsconfig.build.json",
    "build:demo": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "pixi.js": "^8.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "4.1.10"
  }
}
